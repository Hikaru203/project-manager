# --- Backend Configuration ---
# PostgreSQL (matching docker-compose.yml defaults)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/projectdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=123456

# API Gateway URIs (for local run outside docker)
AUTH_SERVICE_URI=http://localhost:8080
PROJECT_SERVICE_URI=http://localhost:8081
TASK_SERVICE_URI=http://localhost:8082
COMMENT_SERVICE_URI=http://localhost:8083
NOTIFICATION_SERVICE_URI=http://localhost:8084
NOTIFICATION_WS_URI=ws://localhost:8084
AUDIT_SERVICE_URI=http://localhost:8085

# --- Frontend Configuration ---
NEXT_PUBLIC_API_URL=http://localhost:8090
